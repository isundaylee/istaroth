{
  "worktree": {
    "setup": "scripts/dev-compose.sh setup",
    "teardown": "scripts/dev-compose.sh down || true"
  },
  "scripts": {
    "Docker Compose Up": {
      "type": "service",
      "command": "scripts/dev-compose.sh up"
    },
    "Show URLs": {
      "command": "scripts/dev-compose.sh urls"
    }
  }
}
