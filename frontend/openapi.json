  "paths": {
    "/api/query/stream": {
      "post": {
        "tags": [
          "query"
        ],
        "summary": "Query Stream",
        "description": "Answer a question, streaming pipeline progress as newline-delimited JSON.\n\nEmits ``step_start``/``step_end`` events as pipeline steps begin and finish,\nand ``answer_chunk`` events carrying fragments of the answer as it is\ngenerated, followed by a terminal ``done`` event carrying the authoritative\n``QueryResponse`` (or an ``error`` event). The client shows every step that\nhas started but not ended, and replaces accumulated chunks with the ``done``\nanswer.",
        "operationId": "query_stream_api_query_stream_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/QueryRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Newline-delimited JSON (application/x-ndjson) stream of progress events, ending with a `done` or `error` event.",
            "content": {
              "application/json": {
                "schema": {
                  "anyOf": [
                    {
                      "$ref": "#/components/schemas/QueryStreamStepStart"
                    },
                    {
                      "$ref": "#/components/schemas/QueryStreamStepEnd"
                    },
                    {
                      "$ref": "#/components/schemas/QueryStreamAnswerChunk"
                    },
                    {
                      "$ref": "#/components/schemas/QueryStreamDone"
                    },
                    {
                      "$ref": "#/components/schemas/QueryStreamError"
                    }
                  ],
                  "title": "Response 200 Query Stream Api Query Stream Post"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
