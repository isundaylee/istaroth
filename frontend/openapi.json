          "file_id": {
            "type": "string",
            "title": "File Id"
          },
          "chunk_index": {
            "type": "integer",
            "title": "Chunk Index"
          },
          "content": {
            "type": "string",
            "title": "Content"
          },
          "metadata": {
            "additionalProperties": true,
            "type": "object",
            "title": "Metadata"
          },
