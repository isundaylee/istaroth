    "/api/library/hierarchy": {
      "get": {
        "tags": [
          "library"
        ],
        "summary": "Get Library Hierarchy",
        "description": "Get the full library hierarchy: every category's document tree.\n\nCategories with a dedicated builder (quests, hangouts) return their pre-baked\nmulti-level tree; any other category returns a flat, depth-1 list of file\nleaves synthesized from the manifest. The corpus is immutable per deployment,\nso the response carries an ETag for free conditional reloads.",
        "operationId": "get_library_hierarchy_api_library_hierarchy_get",
        "parameters": [
          {
            "name": "language",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "description": "Language code (CHS, ENG)",
              "title": "Language"
            },
            "description": "Language code (CHS, ENG)"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
