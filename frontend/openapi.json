          "uuid": {
            "type": "string",
            "title": "Uuid"
          },
          "language": {
            "type": "string",
            "title": "Language"
          },
          "question": {
            "type": "string",
            "title": "Question"
          },
          "answer": {
            "type": "string",
            "title": "Answer"
          },
          "model": {
            "type": "string",
            "title": "Model"
          },
          "k": {
            "type": "integer",
            "title": "K"
          },
          "budget": {
