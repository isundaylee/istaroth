            "type": "integer",
            "title": "Start Index"
          },
          "end_index": {
            "type": "integer",
            "title": "End Index"
          }
        },
        "type": "object",
        "required": [
          "file_id",
          "chunk_index",
          "content",
          "metadata",
          "total_chunks",
          "file_info",
          "start_index",
          "end_index"
        ],
        "title": "CitationResponse",
        "description": "Response model for citation content endpoint."
      },
      "ConversationListResponse": {
        "properties": {
          "conversations": {
            "items": {
              "$ref": "#/components/schemas/ConversationSummary"
            },
            "type": "array",
            "title": "Conversations"
          }
        },
