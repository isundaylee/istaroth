  "components": {
    "schemas": {
      "CitationBatchRequest": {
        "properties": {
          "language": {
            "type": "string",
            "title": "Language"
          },
          "citations": {
            "items": {
              "prefixItems": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ],
              "type": "array",
              "maxItems": 2,
              "minItems": 2
            },
            "type": "array",
            "title": "Citations"
          }
        },
        "type": "object",
        "required": [
          "language",
          "citations"
        ],
        "title": "CitationBatchRequest",
        "description": "Request model for batch citation endpoint."
      },
      "CitationBatchResponse": {
        "properties": {
          "successes": {
