  "components": {
    "schemas": {
      "CitationBatchRequest": {
        "properties": {
          "language": {
            "type": "string",
            "title": "Language"
          },
          "citations": {
            "items": {
              "prefixItems": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ],
              "type": "array",
              "maxItems": 2,
              "minItems": 2
            },
            "type": "array",
            "title": "Citations"
          }
        },
        "type": "object",
        "required": [
          "language",
          "citations"
        ],
        "title": "CitationBatchRequest",
        "description": "Request model for batch citation endpoint."
      },
      "CitationBatchResponse": {
        "properties": {
          "successes": {
            "items": {
              "$ref": "#/components/schemas/CitationResponse"
            },
            "type": "array",
            "title": "Successes"
          },
          "errors": {
            "items": {
              "$ref": "#/components/schemas/CitationError"
            },
            "type": "array",
            "title": "Errors"
          }
        },
        "type": "object",
        "required": [
          "successes",
          "errors"
        ],
        "title": "CitationBatchResponse",
        "description": "Response model for batch citation endpoint."
      },
      "CitationError": {
        "properties": {
          "file_id": {
            "type": "string",
            "title": "File Id"
          },
          "chunk_index": {
            "type": "integer",
            "title": "Chunk Index"
          },
          "error": {
            "type": "string",
            "title": "Error"
          }
        },
        "type": "object",
        "required": [
          "file_id",
          "chunk_index",
          "error"
        ],
        "title": "CitationError",
        "description": "Error details for a failed citation fetch."
      },
      "CitationResponse": {
        "properties": {
          "file_id": {
            "type": "string",
            "title": "File Id"
          },
          "chunk_index": {
            "type": "integer",
            "title": "Chunk Index"
          },
          "content": {
            "type": "string",
            "title": "Content"
          },
          "metadata": {
            "additionalProperties": true,
            "type": "object",
            "title": "Metadata"
          },
          "total_chunks": {
            "type": "integer",
            "title": "Total Chunks"
          },
          "file_info": {
            "$ref": "#/components/schemas/LibraryFileInfo"
          }
        },
        "type": "object",
        "required": [
          "file_id",
          "chunk_index",
          "content",
          "metadata",
          "total_chunks",
          "file_info"
        ],
        "title": "CitationResponse",
        "description": "Response model for citation content endpoint."
      },
      "ConversationListResponse": {
        "properties": {
          "conversations": {
            "items": {
              "$ref": "#/components/schemas/ConversationSummary"
            },
            "type": "array",
            "title": "Conversations"
          }
        },
        "type": "object",
        "required": [
          "conversations"
        ],
        "title": "ConversationListResponse",
        "description": "Response model for listing a client's conversations, newest first."
      },
      "ConversationResponse": {
        "properties": {
          "uuid": {
            "type": "string",
            "title": "Uuid"
          },
          "language": {
            "type": "string",
            "title": "Language"
          },
          "question": {
            "type": "string",
            "title": "Question"
          },
          "answer": {
            "type": "string",
            "title": "Answer"
          },
          "model": {
            "type": "string",
            "title": "Model"
          },
          "k": {
            "type": "integer",
            "title": "K"
          },
          "created_at": {
            "type": "number",
            "title": "Created At"
          },
          "generation_time_seconds": {
            "type": "number",
            "title": "Generation Time Seconds"
          },
          "final_generation_input_text_length": {
            "type": "integer",
            "title": "Final Generation Input Text Length"
          },
          "retrieval_unique_chunk_count": {
            "type": "integer",
            "title": "Retrieval Unique Chunk Count"
          },
          "retrieval_unique_file_count": {
            "type": "integer",
            "title": "Retrieval Unique File Count"
          },
          "short_slug": {
            "type": "string",
            "title": "Short Slug"
          }
        },
        "type": "object",
        "required": [
          "uuid",
          "language",
          "question",
          "answer",
          "model",
          "k",
          "created_at",
          "generation_time_seconds",
          "final_generation_input_text_length",
          "retrieval_unique_chunk_count",
          "retrieval_unique_file_count",
          "short_slug"
        ],
        "title": "ConversationResponse",
        "description": "Response model for conversation retrieval."
      },
      "ConversationSummary": {
        "properties": {
          "id": {
            "type": "integer",
            "title": "Id"
          },
          "uuid": {
            "type": "string",
            "title": "Uuid"
          },
          "question": {
